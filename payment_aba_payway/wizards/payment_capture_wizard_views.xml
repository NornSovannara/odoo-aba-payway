<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="payment_capture_wizard_view_form_aba_payway" model="ir.ui.view">
        <field name="name">payment.aba_payway.capture.wizard.form</field>
        <field name="model">payment.capture.wizard</field>
        <field name="inherit_id" ref="payment.payment_capture_wizard_view_form"/>
        <field name="arch" type="xml">

            <field name="void_remaining_amount" position="attributes">
                <attribute name="readonly">payway_auto_void</attribute>
            </field>
            <field name="void_remaining_amount" position="after">
                <div class="alert alert-info mb-0" role="alert" invisible="not payway_auto_void">
                    <i class="fa fa-info-circle"/> PayWay automatically voids the remaining amount when capturing partially. 
                    The remainder will be voided without an additional API call.
                </div>
            </field>
        </field>
    </record>

</odoo>
