<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="payment_provider_aba_payway" model="payment.provider">
        <field name="name">ABA PayWay</field>
        <field name="image_128" type="base64" file="payment_aba_payway/static/description/icon.png"/>
        <field name="module_id" ref="base.module_payment_aba_payway"/>
        <field name="code">aba_payway</field>
        <field 
            name="payment_method_ids"
            eval="[Command.set([
                ref('payment.payment_method_card'),
                ref('payment_aba_payway.payment_method_payway_abapay_khqr'),
                ref('payment.payment_method_wechat_pay'),
                ref('payment.payment_method_alipay'),
            ])]"
        />
        
        <!-- <field name="inline_form_view_id" ref="inline_form"/> -->
    </record>
</odoo>