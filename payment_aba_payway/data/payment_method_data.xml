<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="payment_method_payway_abapay_khqr" model="payment.method">
        <field name="name">ABA KHQR</field>
        <field name="code">abapay_khqr</field>
        <field name="sequence">10</field>
        <field name="image" type="base64" file="payment_aba_payway/static/src/img/aba_khqr.png"/>
        <field name="support_tokenization">False</field>
        <field name="support_express_checkout">False</field>
        <field name="support_refund">partial</field>
        <field name="supported_currency_ids"
               eval="[Command.set([
                        ref('base.USD'),
                        ref('base.KHR')
                    ])]"
        />
    </record>
</odoo>
