<?xml version='1.0' encoding='utf-8' ?>
<odoo>
    <record id="payment_provider_form_aba_payway" model="ir.ui.view">
        <field name="name">ABA PayWay Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>

        <field name="arch" type="xml">
            <group name="provider_credentials" position="inside">
                <group invisible="code != 'aba_payway'" name="payway_credentials">
                    <group colspan="2">
                        <field name="payway_environment" required="code == 'aba_payway' and state != 'disabled'" placeholder="Select Environment"/>
                        <div class="alert alert-primary" role="alert" invisible="payway_environment != 'sandbox'">
                            Need an ABA PayWay Sandbox account?
                            <a href="https://sandbox.payway.com.kh/login/" target="_blank">
                                Register Here
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right-short" viewBox="0 0 16 16">
                                    <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8"/>
                                </svg>
                            </a>
                        </div>
                    </group> 
                    
                    <group invisible="payway_environment != 'production'" colspan="2" string="Production Credentials">
                        <field name="production_payway_merchant_id" 
                               required="code == 'aba_payway' and state != 'disabled' and payway_environment == 'production'"/>
                        <field name="production_payway_key" 
                               password="True"
                               required="code == 'aba_payway' and state != 'disabled' and payway_environment == 'production'"/>
                        <field name="production_rsa_public_key" 
                               required="code == 'aba_payway' and state != 'disabled' and payway_environment == 'production'"/>
                    </group>
                                 
                    <group invisible="payway_environment != 'sandbox'" colspan="2" string="Sandbox Credentials">
                        <field name="sandbox_payway_merchant_id" 
                               required="code == 'aba_payway' and state != 'disabled' and payway_environment == 'sandbox'"/>
                        <field name="sandbox_payway_key" 
                               password="True"
                               required="code == 'aba_payway' and state != 'disabled' and payway_environment == 'sandbox'"/>
                        <field name="sandbox_rsa_public_key" 
                               required="code == 'aba_payway' and state != 'disabled' and payway_environment == 'sandbox'"/>
                    </group>
                </group>
            </group>

            <field name="capture_manually" position="after">
                <div class="text-muted" invisible="not support_manual_capture or code != 'aba_payway'">
                    Enable this option to hold payment and charge customer only when the order is fulfilled. Disable to collect full payment immediately at purchase.
                </div>
            </field>
        </field>
    </record>
</odoo>