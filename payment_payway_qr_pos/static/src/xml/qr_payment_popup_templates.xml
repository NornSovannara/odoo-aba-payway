<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <!-- Custom QR Payment Popup Template (Simplified) -->
    <t t-name="pos_qr_payment.QRPaymentPopup" owl="1">
        <div role="dialog" class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h4 class="modal-title">QR Payment for <t t-esc="props.orderName"/></h4>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" t-on-click="cancel"/>
                </div>
                <div class="modal-body text-center">
                    <div t-if="state.isLoading" class="d-flex flex-column align-items-center">
                        <i class="fa fa-spinner fa-spin fa-3x text-primary mb-3"></i>
                        <p class="h5">Preparing Payment...</p>
                    </div>
                    <div t-else="">
                        <p class="h5 mb-3 text-info"><t t-esc="state.popupMessage"/></p>
                        <p class="mt-3">
                            <strong class="text-info">Amount: <t t-esc="env.pos.format_currency(props.amount)"/></strong>
                        </p>
                        <p class="text-muted mt-4">
                            Instruct the customer to scan the QR code using their <t t-esc="props.paymentMethodName"/> app.<br/>
                            Once payment is confirmed outside Odoo, click the 'Confirm Payment' button below.
                        </p>
                    </div>

                    <div t-if="state.errorMessage" class="alert alert-danger mt-4" role="alert">
                        <i class="fa fa-exclamation-triangle me-2"/> <t t-esc="state.errorMessage"/>
                    </div>
                </div>
                <div class="modal-footer d-flex justify-content-center">
                    <button class="btn btn-success btn-lg rounded-pill shadow-sm" t-on-click="confirmPayment">
                        <i class="fa fa-check me-2"/>Confirm Payment (Manual)
                    </button>
                    <button class="btn btn-outline-secondary btn-lg rounded-pill shadow-sm ms-3" t-on-click="cancel">
                        <i class="fa fa-times me-2"/>Cancel
                    </button>
                </div>
            </div>
        </div>
    </t>

</templates>
