<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        
        <xpath expr="//p[text()='Powered by Odoo']" position="before">
            <div class="my-custom-receipt-text text-center mt-3">
                <p>Scan ABA KHQR to Pay</p>
            </div>
        </xpath>

        <xpath expr="//div[@id='order-date']" position="after">
            <t t-if="props.data.cashier">
                <div class="pos-receipt-order-data">
                    Cashier: <t t-esc="props.data.cashier_name"/>
                </div>

                <img t-att-src="props.data.qr_image" alt="QR Code"/>
            </t>
        </xpath>
        
    </t>
</templates>