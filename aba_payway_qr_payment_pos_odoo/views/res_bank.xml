<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_bank_form_inherit_account" model="ir.ui.view">
        <field name="name">res.partner.bank.form.inherit.account</field>
        <field name="model">res.partner.bank</field>
        <field name="inherit_id" ref="base.view_partner_bank_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="ABA PayWay Payment Configuration" col="2">
                    <group>
                        <field name="payway_environment" string="Environment"/>
                        <field 
                            name="production_payway_merchant_id"
                            string="Merchant ID"
                            invisible="payway_environment != 'production'"
                        />
                        <field 
                            name="production_payway_key"
                            string="API Key"
                            password="True"
                            invisible="payway_environment != 'production'"
                        />
                        <field
                            name="production_rsa_public_key"
                            string="RSA Public Key"
                            invisible="payway_environment != 'production'"
                        />

                        <field 
                            name="sandbox_payway_merchant_id"
                            string="Merchant ID"
                            invisible="payway_environment != 'sandbox'"
                        />
                        <field 
                            name="sandbox_payway_key"
                            string="API Key"
                            password="True"
                            invisible="payway_environment != 'sandbox'"
                        />
                        <field
                            name="sandbox_rsa_public_key"
                            string="RSA Public Key"
                            invisible="payway_environment != 'sandbox'"
                        />

                    </group>
                    
                    <group>
                        <field 
                            name="digital_qr_lifetime" 
                            string="QR on screen expire time (minutes)" 
                            invisible="payway_environment == 'disable'"
                        />
                        <field 
                            name="bill_qr_lifetime" 
                            string="QR on Bill expire time (minutes)" 
                            invisible="payway_environment == 'disable'"
                        />
                    </group>

                    <div 
                        class="alert alert-primary mx-2 col-sm"
                        role="alert"
                        invisible="payway_environment != 'sandbox'"
                    >
                        Need an ABA PayWay Sandbox account?
                        <a href="https://sandbox.payway.com.kh/login/" target="_blank">
                            Register Here
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-arrow-right-short" viewBox="0 0 16 16">
                                <path fill-rule="evenodd" d="M4 8a.5.5 0 0 1 .5-.5h5.793L8.146 5.354a.5.5 0 1 1 .708-.708l3 3a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708-.708L10.293 8.5H4.5A.5.5 0 0 1 4 8"/>
                            </svg>
                        </a>
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
